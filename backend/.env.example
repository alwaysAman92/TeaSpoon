# Copy to .env and fill in. NEVER commit real secrets.

# Environment: development | production
TEASPOON_ENV=development

# Database. SQLite default for local dev; PostgreSQL in production.
# DATABASE_URL=postgresql+psycopg2://teaspoon:CHANGE_ME@localhost:5432/teaspoon
DATABASE_URL=sqlite:///./teaspoon.db

# Open Food Facts (no key needed; identify the app politely).
OFF_BASE_URL=https://world.openfoodfacts.org
OFF_USER_AGENT=TeaSpoon/5.0 (https://teaspoon.app)

# Google Cloud Vision OCR (Section 10). Leave blank to disable live OCR.
GOOGLE_CLOUD_VISION_API_KEY=

# Gemini API (PRD Section 10). Leave blank to disable fallback brand website lookup.
GEMINI_API_KEY=

# Clerk auth (Section 11). Leave blank to use the X-User-Id header in dev.
CLERK_SECRET_KEY=

# Comma-separated allow-list of browser origins for CORS.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:5173

# OCR confidence gate (Section 10.1).
OCR_MIN_CONFIDENCE=0.6
